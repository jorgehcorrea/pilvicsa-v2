<!-- MAIN CONTENT -->
<div class="tool-wrap pt-8">

  <div class="pilv-section-label"><span>Referencia — Conversión de Unidades</span></div>

  <div class="pilv-calc">
    <div class="pilv-calc-header">
      <div class="icon">📐</div>
      <div>
        <h2>Conversión de Unidades Agrícolas</h2>
        <p>Área, peso, volumen y longitud — unidades del campo al laboratorio. Haz clic en un resultado para verlo en grande.</p>
      </div>
    </div>
    <div class="pilv-calc-body">
      <div class="pilv-row-2">
        <div class="pilv-field">
          <label>Categoría</label>
          <select id="conv-cat" onchange="updateConvUnits()">
            <option value="area">Área</option>
            <option value="peso">Peso / Masa</option>
            <option value="volumen">Volumen</option>
            <option value="longitud">Longitud</option>
          </select>
        </div>
        <div class="pilv-field">
          <label>Unidad de origen</label>
          <select id="conv-from" onchange="calcConversion()"></select>
        </div>
      </div>
      <div class="pilv-row-2">
        <div class="pilv-field">
          <label>Cantidad a convertir</label>
          <input type="number" id="conv-value" placeholder="ej. 1" min="0" step="any" oninput="calcConversion()">
        </div>
        <div class="pilv-field">
          <label>Unidad de destino <span style="font-weight:400;color:#999;">(opcional — muestra todas si vacío)</span></label>
          <select id="conv-to" onchange="calcConversion()">
            <option value="">— Mostrar todas —</option>
          </select>
        </div>
      </div>

      <div class="pilv-result" style="display:block;margin-top:0;">
        <div class="result-title">Equivalencias</div>
        <div id="conv-result-grid"></div>
      </div>

      <div style="margin-top:16px;">
        <button class="pilv-btn" onclick="downloadConvImage()">📱 Descargar como imagen</button>
        <canvas id="conv-card-canvas" style="display:none;"></canvas>
      </div>
    </div>
  </div>

  <div style="text-align:center;padding:20px 0 40px;font-size:.78rem;color:#888;line-height:1.7;">
    Las calculadoras son herramientas de referencia. Consulte siempre con un agrónomo certificado<br>
    antes de aplicar productos o realizar cambios en su planificación de cultivo.<br>
    <a href="localizaciones.html" style="color:#2e5fa3;font-weight:600;">Contactar a un asesor Pilvicsa →</a>
  </div>

</div><!-- /tool-wrap -->

