<script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.3.0/flowbite.min.js"></script>
<script>
var CONV_DATA = {
	area: {
		units: ['Hectárea (ha)', 'Metro cuadrado (m²)', 'Cuadra ecuatoriana', 'Acre', 'Kilómetro cuadrado (km²)'],
		keys:  ['ha', 'm2', 'cuadra', 'acre', 'km2'],
		toBase: { ha:1, m2:0.0001, cuadra:0.7, acre:0.404686, km2:100 },
		fmt: ['4','0','2','4','4']
	},
	peso: {
		units: ['Kilogramo (kg)', 'Gramo (g)', 'Quintal (qq)', 'Libra (lb)', 'Tonelada métrica (t)', 'Miligramo (mg)'],
		keys:  ['kg','g','qq','lb','t','mg'],
		toBase: { kg:1, g:0.001, qq:45.3592, lb:0.453592, t:1000, mg:0.000001 },
		fmt: ['3','0','4','4','4','0']
	},
	volumen: {
		units: ['Litro (L)', 'Mililitro (ml)', 'Galón (gal)', 'Metro cúbico (m³)', 'Centímetro cúbico (cc)'],
		keys:  ['L','ml','gal','m3','cc'],
		toBase: { L:1, ml:0.001, gal:3.78541, m3:1000, cc:0.001 },
		fmt: ['3','0','3','3','0']
	},
	longitud: {
		units: ['Metro (m)', 'Centímetro (cm)', 'Kilómetro (km)', 'Vara (vara)', 'Pulgada (in)', 'Pie (ft)'],
		keys:  ['m','cm','km','vara','in','ft'],
		toBase: { m:1, cm:0.01, km:1000, vara:0.836, in:0.0254, ft:0.3048 },
		fmt: ['4','2','6','4','4','4']
	}
};

function updateConvUnits() {
	var cat  = document.getElementById('conv-cat').value;
	var data = CONV_DATA[cat];
	var selFrom = document.getElementById('conv-from');
	var selTo   = document.getElementById('conv-to');
	var opts = data.units.map(function(u, i) {
		return '<option value="' + data.keys[i] + '">' + u + '</option>';
	}).join('');
	selFrom.innerHTML = opts;
	selTo.innerHTML   = '<option value="">— Mostrar todas —</option>' + opts;
	calcConversion();
}

function calcConversion() {
	var cat   = document.getElementById('conv-cat').value;
	var val   = parseFloat(document.getElementById('conv-value').value);
	var from  = document.getElementById('conv-from').value;
	var toSel = document.getElementById('conv-to');
	var toKey = toSel ? toSel.value : '';
	var data  = CONV_DATA[cat];
	var grid  = document.getElementById('conv-result-grid');
	if (!val && val !== 0) { grid.innerHTML = '<p style="color:#999;font-size:.85rem;">Ingresa un valor para ver las equivalencias.</p>'; return; }
	if (!from) { grid.innerHTML = '<p style="color:#999;font-size:.85rem;">Selecciona la unidad de origen.</p>'; return; }
	var inBase = val * data.toBase[from];
	if (toKey && toKey !== from) {
		var result = inBase / data.toBase[toKey];
		var idx    = data.keys.indexOf(toKey);
		var dp     = parseInt(data.fmt[idx]);
		var disp   = result < 0.001 ? result.toExponential(2) : result.toLocaleString('es-EC', {minimumFractionDigits:0,maximumFractionDigits:dp});
		var fromLabel = data.units[data.keys.indexOf(from)];
		var toLabel   = data.units[idx];
		grid.innerHTML = '<div style="text-align:center;padding:20px 0;">'
			+ '<div style="font-size:.75rem;color:#888;margin-bottom:6px;">' + val.toLocaleString('es-EC') + ' ' + fromLabel + ' equivale a</div>'
			+ '<div style="font-size:2.4rem;font-weight:800;color:#1a4a28;letter-spacing:-1px;">' + disp + '</div>'
			+ '<div style="font-size:1rem;color:#555;margin-top:4px;">' + toLabel + '</div>'
			+ '<div style="margin-top:16px;font-size:.72rem;color:#aaa;">También: <a href="#" onclick="document.getElementById(\'conv-to\').value=\'\';calcConversion();return false;" style="color:#2e5fa3;">ver todas las equivalencias</a></div>'
			+ '</div>';
		return;
	}
	var html = '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));gap:10px;">';
	data.keys.forEach(function(key, i) {
		if (key === from) return;
		var result = inBase / data.toBase[key];
		var dp     = parseInt(data.fmt[i]);
		var disp   = result < 0.001 ? result.toExponential(2) : result.toLocaleString('es-EC', {minimumFractionDigits:0,maximumFractionDigits:dp});
		html += '<div class="pilv-result-item" style="cursor:pointer;" onclick="document.getElementById(\'conv-to\').value=\''+key+'\';calcConversion();">'
			+ '<div class="val" style="font-size:1.2rem;">' + disp + '</div>'
			+ '<div class="unit">' + data.units[i] + '</div>'
			+ '</div>';
	});
	html += '</div><div style="font-size:.72rem;color:#aaa;margin-top:8px;text-align:center;">Haz clic en un resultado para verlo en grande</div>';
	grid.innerHTML = html;
}

function downloadConvImage() {
	var cat  = document.getElementById('conv-cat').value;
	var val  = parseFloat(document.getElementById('conv-value').value);
	var from = document.getElementById('conv-from').value;
	var data = CONV_DATA[cat];
	if (!val && val !== 0) { alert('Ingresa un valor primero.'); return; }
	var fromLabel = data.units[data.keys.indexOf(from)];
	var inBase    = val * data.toBase[from];
	var lines = [];
	data.keys.forEach(function(key, i) {
		if (key === from) return;
		var result = inBase / data.toBase[key];
		var dp     = parseInt(data.fmt[i]);
		var disp   = result < 0.001 ? result.toExponential(2) : result.toLocaleString('es-EC', {minimumFractionDigits:0,maximumFractionDigits:dp});
		lines.push({ val: disp, unit: data.units[i] });
	});
	var W = 540, rowH = 52, padT = 130, padB = 60;
	var H = padT + lines.length * rowH + padB;
	var canvas = document.getElementById('conv-card-canvas');
	canvas.width = W; canvas.height = H;
	var ctx = canvas.getContext('2d');
	ctx.fillStyle = '#f4f9f5'; ctx.fillRect(0,0,W,H);
	ctx.fillStyle = '#2c6e3f'; ctx.fillRect(0,0,W,100);
	ctx.fillStyle = '#fff'; ctx.font = 'bold 22px sans-serif'; ctx.textAlign = 'center';
	ctx.fillText('Pilvicsa — Conversión de Unidades', W/2, 38);
	ctx.font = '15px sans-serif'; ctx.fillStyle = 'rgba(255,255,255,0.85)';
	ctx.fillText(val.toLocaleString('es-EC') + ' ' + fromLabel + ' equivale a:', W/2, 68);
	ctx.font = '12px sans-serif'; ctx.fillStyle = 'rgba(255,255,255,0.6)';
	ctx.fillText('pilvicsa.com.ec', W/2, 90);
	lines.forEach(function(line, i) {
		var y = padT + i * rowH;
		ctx.fillStyle = i % 2 === 0 ? '#fff' : '#f0f7f0';
		ctx.fillRect(20, y, W-40, rowH-4);
		ctx.fillStyle = '#1a4a28'; ctx.font = 'bold 18px sans-serif'; ctx.textAlign = 'left';
		ctx.fillText(line.val, 36, y+31);
		ctx.fillStyle = '#666'; ctx.font = '13px sans-serif'; ctx.textAlign = 'right';
		ctx.fillText(line.unit, W-36, y+31);
	});
	ctx.fillStyle = '#aaa'; ctx.font = '11px sans-serif'; ctx.textAlign = 'center';
	ctx.fillText('Generado por Pilvicsa · ' + new Date().toLocaleDateString('es-EC'), W/2, H-20);
	var link = document.createElement('a');
	link.download = 'conversion-pilvicsa.png';
	link.href = canvas.toDataURL('image/png');
	link.click();
}

window.addEventListener('DOMContentLoaded', function() {
	updateConvUnits();
	calcConversion();
});
</script>
</body>
</html>
