  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=Syne:wght@700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="dist/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.3.0/flowbite.min.css">
  <style>
    #main-navbar { background-color: #fff; box-shadow: 0 1px 8px rgba(0,0,0,0.07); }
    body { background: #eef2f7; }
    .tool-wrap { max-width: 860px; margin: 0 auto; padding: 0 16px 60px; }
    .pilv-section-label { display:flex;align-items:center;gap:12px;margin:36px 0 20px; }
    .pilv-section-label span { font-size:.65rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:#2e5fa3;white-space:nowrap; }
    .pilv-section-label::before,.pilv-section-label::after { content:'';flex:1;height:1px;background:#d0ddf5; }
    .pilv-calc { background:#fff;border-radius:12px;border:1px solid #dde8dd;overflow:hidden;margin-bottom:32px;box-shadow:0 2px 16px rgba(44,110,63,0.07); }
    .pilv-calc-header { background:#1a4a28;padding:18px 24px;display:flex;align-items:center;gap:12px;color:#fff; }
    .pilv-calc-header .icon { font-size:1.8rem;line-height:1; }
    .pilv-calc-header h2 { font-size:1.1rem;font-weight:700;margin:0 0 2px; }
    .pilv-calc-header p { font-size:.8rem;opacity:.75;margin:0; }
    .pilv-calc-body { padding:24px; }
    .pilv-field { margin-bottom:16px; }
    .pilv-field label { display:block;font-size:.82rem;font-weight:600;color:#333;margin-bottom:6px; }
    .pilv-field input,.pilv-field select { width:100%;padding:10px 12px;border:1.5px solid #dde8dd;border-radius:8px;font-size:.9rem;font-family:inherit;background:#fafdfa;transition:border-color .15s; }
    .pilv-field input:focus,.pilv-field select:focus { outline:none;border-color:#2c6e3f; }
    .pilv-row-2 { display:grid;grid-template-columns:1fr 1fr;gap:16px; }
    @media(max-width:600px){ .pilv-row-2 { grid-template-columns:1fr; } }
    .pilv-btn { display:inline-block;padding:11px 24px;background:#2c6e3f;color:#fff;border:none;border-radius:8px;font-size:.88rem;font-weight:700;cursor:pointer;font-family:inherit;transition:background .15s; }
    .pilv-btn:hover { background:#1a4a28; }
    .pilv-result { background:#d0ddf5;border-left:4px solid #2e5fa3;border-radius:0 10px 10px 0;padding:16px 20px;margin-top:16px; }
    .pilv-result .result-title { font-size:.65rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:#2e5fa3;margin-bottom:12px; }
    .pilv-result-item { background:#fff;border-radius:8px;padding:12px;text-align:center;box-shadow:0 1px 4px rgba(0,0,0,.06); }
    .pilv-result-item .val { font-size:1.4rem;font-weight:800;color:#1a4a28;line-height:1.2; }
    .pilv-result-item .unit { font-size:.72rem;color:#888;margin-top:2px; }
    .pilv-btn-ics { display:inline-flex;align-items:center;gap:8px;padding:10px 20px;background:#fff;color:#1a73e8;border:1.5px solid #1a73e8;border-radius:8px;font-size:.83rem;font-weight:700;cursor:pointer;font-family:inherit;text-decoration:none;transition:background .15s;margin-top:14px; }
    .pilv-btn-ics:hover { background:#e8f0fe; }
    .tool-nav-pills { display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px; }
    .tool-nav-pills a { padding:8px 16px;border-radius:99px;font-size:.78rem;font-weight:700;text-decoration:none;border:1.5px solid #c0cfe0;color:#2e5fa3;background:#fff;transition:all .15s; }
    .tool-nav-pills a.active,.tool-nav-pills a:hover { background:#2e5fa3;color:#fff;border-color:#2e5fa3; }
  </style>
