<!-- PAGE HERO -->
<div class="bg-pilvicsa-dark pt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-xs text-white/40 mb-4" aria-label="Breadcrumb">
      <a href="index.html" class="hover:text-white/70 transition">Inicio</a>
      <span class="mx-2">/</span>
      <span class="text-white/70">Herramientas</span>
      <span class="mx-2">/</span>
      <span class="text-white/70">Planificación</span>
    </nav>
    <h1 class="font-display font-black text-3xl lg:text-4xl text-white mb-2">📋 Planificación de Siembra</h1>
    <p class="text-white/50 text-sm max-w-lg">Calendario de trasplante, rotación de cultivos y densidad de siembra — planifica tu producción y exporta a tu calendario.</p>
    <div class="tool-nav-pills mt-6">
      <a href="herramientas-planificacion.html" class="active">📋 Planificación</a>
      <a href="herramientas-cuidado.html">🌿 Cuidado del Cultivo</a>
      <a href="herramientas-conversion.html">📐 Conversión de Unidades</a>
    </div>
  </div>
</div>

<!-- MAIN CONTENT -->
<div class="tool-wrap pt-8">

  <!-- CALCULATOR 1 — TRANSPLANT CALENDAR -->
  <div class="pilv-section-label"><span>Planificación 1 — Calendario de Trasplante</span></div>
  <div class="pilv-calc">
    <div class="pilv-calc-header">
      <div class="icon">📅</div>
      <div>
        <h2>Calendario de Trasplante desde Cosecha</h2>
        <p>Ingresa tu fecha objetivo de cosecha y calcula cuándo solicitar las plántulas</p>
      </div>
    </div>
    <div class="pilv-calc-body">
      <div class="pilv-row-2">
        <div class="pilv-field">
          <label>Fecha objetivo de cosecha</label>
          <input type="date" id="cal-harvest">
        </div>
        <div class="pilv-field">
          <label>Cultivo</label>
          <select id="cal-crop" onchange="fillCalDays()">
            <option value="">— Seleccionar cultivo —</option>
            <optgroup label="Hortalizas">
              <option value="70,21,7,14">Tomate (70 días campo + 21 vivero)</option>
              <option value="80,25,7,14">Pimiento (80 días campo + 25 vivero)</option>
              <option value="75,21,7,14">Brócoli (75 días campo + 21 vivero)</option>
              <option value="60,18,7,14">Lechuga (60 días campo + 18 vivero)</option>
              <option value="55,18,5,14">Col / Repollo (55 días campo + 18 vivero)</option>
              <option value="90,21,7,14">Melón (90 días campo + 21 vivero)</option>
              <option value="85,21,7,14">Pepino (85 días campo + 21 vivero)</option>
              <option value="75,21,7,14">Coliflor (75 días campo + 21 vivero)</option>
            </optgroup>
            <optgroup label="Flores de Corte">
              <option value="110,28,10,21">Gerbera (110 días campo + 28 vivero)</option>
              <option value="90,21,7,21">Clavel (90 días campo + 21 vivero)</option>
              <option value="100,25,7,21">Limonium / Statice (100 días + 25 vivero)</option>
              <option value="95,25,10,21">Eringium (95 días campo + 25 vivero)</option>
              <option value="90,21,7,21">Helichrysum (90 días campo + 21 vivero)</option>
            </optgroup>
            <optgroup label="Cultivos de Costa">
              <option value="180,45,14,30">Cacao — CCN-51 (180 días + 45 vivero)</option>
              <option value="240,60,14,30">Maracuyá (240 días campo + 60 vivero)</option>
              <option value="270,60,14,30">Papaya (270 días campo + 60 vivero)</option>
            </optgroup>
            <optgroup label="Personalizado">
              <option value="custom">Ingresar días manualmente</option>
            </optgroup>
          </select>
        </div>
      </div>
      <div id="cal-custom-fields" style="display:none;">
        <div class="pilv-row-3">
          <div class="pilv-field"><label>Días en campo hasta cosecha</label><input type="number" id="cal-field-days" placeholder="ej. 70" min="1"></div>
          <div class="pilv-field"><label>Días en vivero</label><input type="number" id="cal-nursery-days" placeholder="ej. 21" min="1"></div>
          <div class="pilv-field"><label>Días de endurecimiento</label><input type="number" id="cal-harden-days" placeholder="ej. 7" min="0"></div>
        </div>
      </div>
      <div class="pilv-field">
        <label>Días de anticipación para solicitar a Pilvicsa</label>
        <select id="cal-order-days">
          <option value="7">7 días antes del trasplante (mínimo recomendado)</option>
          <option value="14" selected>14 días antes del trasplante (recomendado)</option>
          <option value="21">21 días antes del trasplante (ideal para volúmenes grandes)</option>
          <option value="30">30 días antes (programación de temporada)</option>
        </select>
      </div>
      <button class="pilv-btn" onclick="calcCalendar()">📅 Calcular calendario</button>
      <button class="pilv-btn-secondary" onclick="resetCal()">Limpiar</button>
      <div id="cal-result" class="pilv-calendar-result" style="margin-top:20px;">
        <div style="font-size:.72rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:#2c6e3f;margin-bottom:16px;">Calendario de producción</div>
        <div class="pilv-timeline" id="cal-timeline"></div>
        <div style="background:#fff3cd;border-left:4px solid #e6a817;border-radius:0 8px 8px 0;padding:14px 18px;margin-top:16px;font-size:.82rem;color:#7a5900;">
          ⚠️ <strong>Nota:</strong> Estos días son estimaciones promedio. Consulte con su asesor Pilvicsa para confirmar disponibilidad y ajustar según su zona climática.
        </div>
        <div class="pilv-cal-export" id="cal-export-block" style="display:none;">
          <div class="export-title">📥 Agregar a tu Calendario</div>
          <p>Descarga el archivo .ics para importar todas las fechas clave directamente a Google Calendar, Apple Calendar, Outlook o cualquier app de calendario.</p>
          <div class="pilv-export-btns">
            <a id="cal-ics-link" href="#" class="pilv-btn-ics" download="calendario-pilvicsa.ics">📅 Descargar archivo .ics</a>
            <a id="cal-google-link" href="#" target="_blank" rel="noopener noreferrer" class="pilv-btn-ics" style="color:#2c6e3f;border-color:#2c6e3f;">🗓 Abrir en Google Calendar</a>
            <button class="pilv-btn-ics" style="color:#555;border-color:#ccc;" onclick="downloadCalImage()">📱 Guardar imagen</button>
          </div>
        </div>
        <canvas id="cal-img-canvas" style="display:none;"></canvas>
      </div>
    </div>
  </div>

  <!-- CALCULATOR 2 — CROP ROTATION -->
  <div class="pilv-section-label"><span>Planificación 2 — Rotación de Cultivos</span></div>
  <div class="pilv-calc">
    <div class="pilv-calc-header">
      <div class="icon">🔄</div>
      <div>
        <h2>Calendario de Rotación de Cultivos</h2>
        <p>Selecciona el cultivo actual — recibe sugerencias de rotación y exporta el calendario</p>
      </div>
    </div>
    <div class="pilv-calc-body">
      <div class="pilv-row-2">
        <div class="pilv-field">
          <label>Cultivo actual en el lote</label>
          <select id="rot-crop">
            <option value="">— Seleccionar —</option>
            <optgroup label="Hortalizas">
              <option value="tomate">Tomate</option><option value="pimiento">Pimiento</option>
              <option value="brocoli">Brócoli / Coliflor</option><option value="lechuga">Lechuga / Espinaca</option>
              <option value="cebolla">Cebolla / Ajo</option><option value="zanahoria">Zanahoria / Remolacha</option>
              <option value="pepino">Pepino / Melón / Sandía</option><option value="maiz">Maíz</option><option value="papa">Papa</option>
            </optgroup>
            <optgroup label="Leguminosas (abono verde)">
              <option value="frejol">Fréjol / Chocho</option><option value="arveja">Arveja / Habas</option>
            </optgroup>
            <optgroup label="Flores">
              <option value="gerbera">Gerbera</option><option value="clavel">Clavel</option>
            </optgroup>
          </select>
        </div>
        <div class="pilv-field">
          <label>Fecha de inicio del cultivo actual</label>
          <input type="date" id="rot-start">
        </div>
      </div>
      <div class="pilv-field">
        <label>Número de lotes / parcelas en rotación</label>
        <select id="rot-plots">
          <option value="2">2 lotes</option><option value="3" selected>3 lotes</option><option value="4">4 lotes</option>
        </select>
      </div>
      <button class="pilv-btn" onclick="calcRotation()">🔄 Calcular rotación</button>
      <button class="pilv-btn-secondary" onclick="resetRot()">Limpiar</button>
      <div id="rot-result" class="pilv-calendar-result" style="margin-top:20px;">
        <div id="rot-warning" style="background:#fff3cd;border-left:4px solid #e6a817;border-radius:0 8px 8px 0;padding:14px 18px;margin-bottom:16px;font-size:.82rem;color:#7a5900;display:none;"></div>
        <div style="font-size:.72rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:#2c6e3f;margin-bottom:16px;">Plan de rotación por lote</div>
        <div id="rot-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;"></div>
        <div class="pilv-cal-export" style="margin-top:20px;">
          <div class="export-title">📥 Exportar plan</div>
          <p>Descarga el calendario de rotación para tu app o como imagen para el celular.</p>
          <div class="pilv-export-btns">
            <a id="rot-ics-link" href="#" class="pilv-btn-ics" download="rotacion-pilvicsa.ics">📅 Descargar .ics</a>
            <button class="pilv-btn-ics" style="color:#2c6e3f;border-color:#2c6e3f;" onclick="downloadRotImage()">📱 Guardar imagen</button>
          </div>
        </div>
        <canvas id="rot-canvas" style="display:none;"></canvas>
      </div>
    </div>
  </div>

  <!-- CALCULATOR 3 — PLANTING DENSITY -->
  <div class="pilv-section-label"><span>Planificación 3 — Densidad de Siembra</span></div>
  <div class="pilv-calc">
    <div class="pilv-calc-header">
      <div class="icon">🌱</div>
      <div>
        <h2>Densidad de Siembra por Hectárea</h2>
        <p>Calcula plantas necesarias o área requerida según el espaciamiento</p>
      </div>
    </div>
    <div class="pilv-calc-body">
      <div class="pilv-tabs" data-prefix="dens">
        <button class="pilv-tab active" data-target="dens-modo-area" onclick="switchTab('dens','dens-modo-area')">Tengo un área → ¿Cuántas plantas?</button>
        <button class="pilv-tab" data-target="dens-modo-plantas" onclick="switchTab('dens','dens-modo-plantas')">Tengo plantas → ¿Cuánta área?</button>
      </div>
      <!-- Mode A: area → plants -->
      <div id="dens-modo-area" class="pilv-tab-content active">
        <div class="pilv-row-2">
          <div class="pilv-field">
            <label>Unidad de medida</label>
            <div class="pilv-unit-toggle">
              <button class="pilv-unit-btn active" onclick="setUnit('ha')" id="unit-btn-ha">Hectáreas (ha)</button>
              <button class="pilv-unit-btn" onclick="setUnit('m2')" id="unit-btn-m2">Metros² (m²)</button>
              <button class="pilv-unit-btn" onclick="setUnit('cuadra')" id="unit-btn-cuadra">Cuadras</button>
            </div>
          </div>
          <div class="pilv-field">
            <label id="dens-area-label">Área de siembra (hectáreas)</label>
            <input type="number" id="dens-area" placeholder="ej. 2.5" min="0.001" step="0.01">
            <div class="hint" id="dens-area-hint">1 ha = 10,000 m²  ·  1 cuadra (Ec) ≈ 0.7 ha</div>
          </div>
        </div>
        <div class="pilv-row-2">
          <div class="pilv-field">
            <label>Cultivo (referencia rápida)</label>
            <select id="dens-crop-a" onchange="fillSpacingA()">
              <option value="">— Seleccionar cultivo —</option>
              <option value="0.5,0.4">Tomate bajo cubierta (0.5 × 0.4 m)</option>
              <option value="0.6,0.5">Tomate campo abierto (0.6 × 0.5 m)</option>
              <option value="0.35,0.3">Pimiento (0.35 × 0.3 m)</option>
              <option value="0.45,0.35">Brócoli / Coliflor (0.45 × 0.35 m)</option>
              <option value="0.3,0.25">Lechuga (0.3 × 0.25 m)</option>
              <option value="0.4,0.3">Cebolla de rama (0.4 × 0.3 m)</option>
              <option value="0.5,0.5">Melón / Sandía (0.5 × 0.5 m)</option>
              <option value="3.0,3.0">Aguacate (3 × 3 m)</option>
              <option value="6.0,6.0">Cítricos (6 × 6 m)</option>
              <option value="3.0,2.5">Cacao (3 × 2.5 m)</option>
              <option value="2.0,1.5">Gerbera (2 × 1.5 m)</option>
              <option value="1.2,0.15">Clavel (1.2 × 0.15 m)</option>
              <option value="custom">Personalizado</option>
            </select>
          </div>
          <div class="pilv-field">
            <label>Unidad de espaciamiento</label>
            <div class="pilv-unit-toggle">
              <button class="pilv-unit-btn active" onclick="setSpacingUnit('m')" id="sp-btn-m">Metros (m)</button>
              <button class="pilv-unit-btn" onclick="setSpacingUnit('cm')" id="sp-btn-cm">Centímetros</button>
              <button class="pilv-unit-btn" onclick="setSpacingUnit('vara')" id="sp-btn-vara">Varas</button>
            </div>
          </div>
        </div>
        <div class="pilv-row-2">
          <div class="pilv-field"><label id="dens-hileras-a-label">Distancia entre hileras (m)</label><input type="number" id="dens-hileras-a" placeholder="ej. 0.50" min="0.01" step="0.01"></div>
          <div class="pilv-field"><label id="dens-plantas-a-label">Distancia entre plantas (m)</label><input type="number" id="dens-plantas-a" placeholder="ej. 0.40" min="0.01" step="0.01"></div>
        </div>
        <div class="pilv-field">
          <label>Factor de pérdida esperada (%)</label>
          <select id="dens-loss-a">
            <option value="0">0% — Sin margen adicional</option>
            <option value="5" selected>5% — Margen estándar recomendado</option>
            <option value="10">10% — Condiciones variables</option>
            <option value="15">15% — Alta incertidumbre</option>
          </select>
        </div>
        <button class="pilv-btn" onclick="calcDensArea()">🌱 Calcular plantas necesarias</button>
        <button class="pilv-btn-secondary" onclick="resetDens()">Limpiar</button>
        <div id="dens-result-area" class="pilv-result">
          <div class="result-title">Resultado — Densidad de Siembra</div>
          <div class="pilv-result-grid" id="dens-result-area-grid"></div>
          <div class="pilv-result-note" id="dens-result-area-note"></div>
          <button class="pilv-btn-ics" style="color:#555;border-color:#ccc;margin-top:12px;" onclick="downloadDensImage()">📱 Guardar imagen del resultado</button>
          <canvas id="dens-img-canvas" style="display:none;"></canvas>
        </div>
        <div class="pilv-field-viz" id="pilv-viz-wrap" style="display:none;">
          <div class="viz-label">Vista de campo — disposición de plantas</div>
          <canvas id="pilv-field-canvas" width="560" height="300" style="max-width:100%;border-radius:6px;display:block;margin:0 auto;"></canvas>
          <div style="font-size:.72rem;color:#888;margin-top:8px;" id="pilv-viz-caption"></div>
        </div>
      </div>
      <!-- Mode B: plants → area -->
      <div id="dens-modo-plantas" class="pilv-tab-content">
        <div class="pilv-row-2">
          <div class="pilv-field"><label>Número de plantas disponibles</label><input type="number" id="dens-nplants" placeholder="ej. 15000" min="1"></div>
          <div class="pilv-field">
            <label>Cultivo (referencia rápida)</label>
            <select id="dens-crop-b" onchange="fillSpacingB()">
              <option value="">— Seleccionar cultivo —</option>
              <option value="0.5,0.4">Tomate bajo cubierta (0.5 × 0.4 m)</option>
              <option value="0.6,0.5">Tomate campo abierto (0.6 × 0.5 m)</option>
              <option value="0.35,0.3">Pimiento (0.35 × 0.3 m)</option>
              <option value="0.45,0.35">Brócoli / Coliflor (0.45 × 0.35 m)</option>
              <option value="0.3,0.25">Lechuga (0.3 × 0.25 m)</option>
              <option value="0.4,0.3">Cebolla de rama (0.4 × 0.3 m)</option>
              <option value="0.5,0.5">Melón / Sandía (0.5 × 0.5 m)</option>
              <option value="3.0,3.0">Aguacate (3 × 3 m)</option>
              <option value="6.0,6.0">Cítricos (6 × 6 m)</option>
              <option value="3.0,2.5">Cacao (3 × 2.5 m)</option>
              <option value="custom">Personalizado</option>
            </select>
          </div>
        </div>
        <div class="pilv-row-2">
          <div class="pilv-field"><label id="dens-hileras-b-label">Distancia entre hileras (m)</label><input type="number" id="dens-hileras-b" placeholder="ej. 0.50" min="0.01" step="0.01"></div>
          <div class="pilv-field"><label id="dens-plantas-b-label">Distancia entre plantas (m)</label><input type="number" id="dens-plantas-b" placeholder="ej. 0.40" min="0.01" step="0.01"></div>
        </div>
        <div class="hint" style="margin-top:-10px;margin-bottom:16px;">1 vara ≈ 0.836 m</div>
        <button class="pilv-btn" onclick="calcDensPlants()">🌱 Calcular área requerida</button>
        <button class="pilv-btn-secondary" onclick="resetDens()">Limpiar</button>
        <div id="dens-result-plants" class="pilv-result">
          <div class="result-title">Resultado — Área Requerida</div>
          <div class="pilv-result-grid" id="dens-result-plants-grid"></div>
          <div class="pilv-result-note" id="dens-result-plants-note"></div>
        </div>
      </div>
    </div>
  </div>

  <div style="text-align:center;padding:20px 0 40px;font-size:.78rem;color:#888;line-height:1.7;">
    Las calculadoras son herramientas de referencia. Consulte siempre con un agrónomo certificado<br>
    antes de aplicar productos o realizar cambios en su planificación de cultivo.<br>
    <a href="localizaciones.html" style="color:#2c6e3f;font-weight:600;">Contactar a un asesor Pilvicsa →</a>
  </div>

</div><!-- /tool-wrap -->

