<!DOCTYPE html>
<html lang="es-EC" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Planificación de Siembra | Herramientas Pilvicsa</title>
  <meta name="description" content="Calendario de trasplante, rotación de cultivos y densidad de siembra por hectárea. Herramientas agrícolas Pilvicsa.">
  <link rel="canonical" href="https://pilvicsa.com.ec/herramientas-planificacion.html">
  <link rel="icon" href="images/pilvicsa.ico" type="image/x-icon">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Pilvicsa">
  <meta property="og:title" content="Planificación de Siembra | Pilvicsa">
  <meta property="og:image" content="https://pilvicsa.com.ec/images/logo@2x.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=Syne:wght@700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="dist/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.3.0/flowbite.min.css">
  <style>
    #main-navbar { background-color: #fff; box-shadow: 0 1px 8px rgba(0,0,0,0.07); }
    body { background: #eef2f7; }
    .tool-wrap { max-width: 860px; margin: 0 auto; padding: 0 16px 60px; }
    .pilv-section-label { display:flex;align-items:center;gap:12px;margin:36px 0 20px; }
    .pilv-section-label span { font-size:.65rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:#2c6e3f;white-space:nowrap; }
    .pilv-section-label::before,.pilv-section-label::after { content:'';flex:1;height:1px;background:#d4e9d8; }
    .pilv-calc { background:#fff;border-radius:12px;border:1px solid #dde8dd;overflow:hidden;margin-bottom:32px;box-shadow:0 2px 16px rgba(44,110,63,0.07); }
    .pilv-calc-header { background:#1a4a28;padding:18px 24px;display:flex;align-items:center;gap:12px;color:#fff; }
    .pilv-calc-header .icon { font-size:1.8rem;line-height:1; }
    .pilv-calc-header h2 { font-size:1.1rem;font-weight:700;margin:0 0 2px; }
    .pilv-calc-header p { font-size:.8rem;opacity:.75;margin:0; }
    .pilv-calc-body { padding:24px; }
    .pilv-field { margin-bottom:16px; }
    .pilv-field label { display:block;font-size:.82rem;font-weight:600;color:#333;margin-bottom:6px; }
    .pilv-field input,.pilv-field select { width:100%;padding:10px 12px;border:1.5px solid #dde8dd;border-radius:8px;font-size:.9rem;font-family:inherit;background:#fafdfa;transition:border-color .15s; }
    .pilv-field input:focus,.pilv-field select:focus { outline:none;border-color:#2c6e3f; }
    .pilv-row-2 { display:grid;grid-template-columns:1fr 1fr;gap:16px; }
    .pilv-row-3 { display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px; }
    @media(max-width:600px){ .pilv-row-2,.pilv-row-3 { grid-template-columns:1fr; } }
    .pilv-btn { display:inline-block;padding:11px 24px;background:#2c6e3f;color:#fff;border:none;border-radius:8px;font-size:.88rem;font-weight:700;cursor:pointer;font-family:inherit;transition:background .15s; }
    .pilv-btn:hover { background:#1a4a28; }
    .pilv-btn-secondary { display:inline-block;padding:11px 20px;background:#fff;color:#555;border:1.5px solid #ccc;border-radius:8px;font-size:.88rem;font-weight:600;cursor:pointer;font-family:inherit;margin-left:10px;transition:background .15s; }
    .pilv-btn-secondary:hover { background:#f5f5f5; }
    .pilv-result { background:#d4e9d8;border-left:4px solid #2c6e3f;border-radius:0 10px 10px 0;padding:16px 20px;margin-top:16px;display:none; }
    .pilv-result.show { display:block; }
    .pilv-result .result-title { font-size:.65rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:#2c6e3f;margin-bottom:12px; }
    .pilv-result-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px;margin-bottom:8px; }
    .pilv-result-item { background:#fff;border-radius:8px;padding:12px;text-align:center;box-shadow:0 1px 4px rgba(0,0,0,.06); }
    .pilv-result-item .val { font-size:1.4rem;font-weight:800;color:#1a4a28;line-height:1.2; }
    .pilv-result-item .unit { font-size:.72rem;color:#888;margin-top:2px; }
    .pilv-result-note { font-size:.82rem;color:#444;margin-top:12px;line-height:1.6; }
    .hint { font-size:.72rem;color:#999;margin-top:4px; }
    .pilv-btn-ics { display:inline-flex;align-items:center;gap:8px;padding:10px 20px;background:#fff;color:#1a73e8;border:1.5px solid #1a73e8;border-radius:8px;font-size:.83rem;font-weight:700;cursor:pointer;font-family:inherit;text-decoration:none;transition:background .15s;margin-top:14px; }
    .pilv-btn-ics:hover { background:#e8f0fe; }
    .pilv-cal-export { margin-top:20px;padding:18px 20px;background:#f0f6ff;border-left:4px solid #1a73e8;border-radius:0 8px 8px 0; }
    .pilv-cal-export .export-title { font-size:.72rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:#1a73e8;margin-bottom:8px; }
    .pilv-cal-export p { font-size:.82rem;color:#555;margin:0 0 12px;line-height:1.5; }
    .pilv-export-btns { display:flex;gap:10px;flex-wrap:wrap;align-items:center; }
    .pilv-calendar-result { display:none; }
    .pilv-calendar-result.show { display:block; }
    .pilv-timeline { margin-top:12px;border-left:2px solid #d4e9d8;padding-left:24px;position:relative; }
    .pilv-timeline-item { position:relative;margin-bottom:16px;padding:14px 16px;border:1px solid #dde8dd;border-radius:8px;background:#fff; }
    .pilv-timeline-item::before { content:'';position:absolute;left:-30px;top:18px;width:12px;height:12px;border-radius:50%;background:#2c6e3f;border:2px solid #fff;box-shadow:0 0 0 2px #2c6e3f; }
    .pilv-timeline-item.highlight { border-color:#2c6e3f;background:#f4f9f5; }
    .pilv-timeline-item.highlight::before { background:#1a4a28;width:16px;height:16px;left:-32px;top:16px; }
    .pilv-timeline-item .tl-label { font-size:.7rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#2c6e3f;margin-bottom:3px; }
    .pilv-timeline-item .tl-date { font-size:1.1rem;font-weight:700;color:#1a1a1a; }
    .pilv-timeline-item .tl-desc { font-size:.78rem;color:#777;margin-top:2px; }
    .pilv-tabs { display:flex;gap:0;margin-bottom:20px;border:1.5px solid #dde8dd;border-radius:8px;overflow:hidden; }
    .pilv-tab { flex:1;padding:10px;border:none;background:#fafdfa;cursor:pointer;font-size:.82rem;font-weight:600;color:#666;font-family:inherit;transition:all .15s; }
    .pilv-tab:not(:last-child) { border-right:1.5px solid #dde8dd; }
    .pilv-tab.active { background:#2c6e3f;color:#fff; }
    .pilv-tab-content { display:none; }
    .pilv-tab-content.active { display:block; }
    .pilv-unit-toggle { display:inline-flex;border:1.5px solid #dde8dd;border-radius:7px;overflow:hidden;margin-bottom:12px; }
    .pilv-unit-btn { padding:7px 14px;border:none;background:#fafdfa;cursor:pointer;font-size:.78rem;font-weight:600;color:#666;font-family:inherit;transition:all .15s; }
    .pilv-unit-btn:not(:last-child) { border-right:1.5px solid #dde8dd; }
    .pilv-unit-btn.active { background:#2c6e3f;color:#fff; }
    .pilv-field-viz { margin-top:20px;background:#f4f9f5;border:1.5px solid #dde8dd;border-radius:10px;padding:20px;text-align:center; }
    .pilv-field-viz .viz-label { font-size:.7rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:#2c6e3f;margin-bottom:12px; }
    .tool-nav-pills { display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px; }
    .tool-nav-pills a { padding:8px 16px;border-radius:99px;font-size:.78rem;font-weight:700;text-decoration:none;border:1.5px solid rgba(255,255,255,0.4);color:rgba(255,255,255,0.8);background:rgba(255,255,255,0.1);transition:all .15s; }
    .tool-nav-pills a.active,.tool-nav-pills a:hover { background:rgba(255,255,255,0.25);border-color:rgba(255,255,255,0.7);color:#fff; }
  </style>
</head>
<body class="font-sans text-gray-900">

