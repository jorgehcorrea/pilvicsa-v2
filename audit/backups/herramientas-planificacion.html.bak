<script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.3.0/flowbite.min.js"></script>
<script>
/* ── Utility ── */
function fmt(n,dec){return Number(n).toLocaleString('es-EC',{minimumFractionDigits:dec||0,maximumFractionDigits:dec||0});}
function addDays(date,days){var d=new Date(date);d.setDate(d.getDate()+days);return d;}
function subDays(date,days){var d=new Date(date);d.setDate(d.getDate()-days);return d;}
function fmtDate(d){var days=['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'],months=['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];return days[d.getDay()]+', '+d.getDate()+' de '+months[d.getMonth()]+' de '+d.getFullYear();}
function resultItem(val,unit){return '<div class="pilv-result-item"><div class="val">'+val+'</div><div class="unit">'+unit+'</div></div>';}
function switchTab(prefix,activeId){document.querySelectorAll('[id^="'+prefix+'-modo-"]').forEach(function(el){el.classList.toggle('active',el.id===activeId);});document.querySelectorAll('[data-prefix="'+prefix+'"] .pilv-tab').forEach(function(btn){btn.classList.toggle('active',btn.dataset.target===activeId);});}
function pad(n){return n<10?'0'+n:''+n;}
function toICSDate(d){return d.getFullYear()+''+pad(d.getMonth()+1)+''+pad(d.getDate());}
function makeICSEvent(uid,summary,date,description){var ds=toICSDate(date),de=toICSDate(new Date(date.getTime()+86400000));return['BEGIN:VEVENT','UID:'+uid+'@pilvicsa.com.ec','DTSTART;VALUE=DATE:'+ds,'DTEND;VALUE=DATE:'+de,'SUMMARY:🌱 '+summary,'DESCRIPTION:'+description,'CATEGORIES:Pilvicsa,Agricultura','BEGIN:VALARM','TRIGGER:-P1D','ACTION:DISPLAY','DESCRIPTION:Recordatorio: '+summary,'END:VALARM','END:VEVENT'].join('\r\n');}

/* ── Area unit selector ── */
var currentUnit='ha',CUADRA_TO_HA=0.7;
function setUnit(unit){currentUnit=unit;var labels={ha:'Área de siembra (hectáreas)',m2:'Área de siembra (metros cuadrados)',cuadra:'Área de siembra (cuadras)'},hints={ha:'1 ha = 10,000 m²  ·  1 cuadra (Ec) ≈ 0.7 ha',m2:'1 m² = 0.0001 ha  ·  10,000 m² = 1 ha',cuadra:'1 cuadra ≈ 0.7 ha ≈ 7,000 m²'},ph={ha:'ej. 2.5',m2:'ej. 25000',cuadra:'ej. 3.5'};document.getElementById('dens-area-label').textContent=labels[unit];document.getElementById('dens-area-hint').textContent=hints[unit];document.getElementById('dens-area').placeholder=ph[unit];document.getElementById('dens-area').value='';['ha','m2','cuadra'].forEach(function(u){var btn=document.getElementById('unit-btn-'+u);if(btn)btn.classList.toggle('active',u===unit);});document.getElementById('dens-result-area').classList.remove('show');var viz=document.getElementById('pilv-viz-wrap');if(viz)viz.style.display='none';}
function toHectares(val){if(currentUnit==='ha')return val;if(currentUnit==='m2')return val/10000;if(currentUnit==='cuadra')return val*CUADRA_TO_HA;return val;}

/* ── Spacing unit selector ── */
var currentSpacingUnit='m',VARA_TO_M=0.836;
function setSpacingUnit(unit){currentSpacingUnit=unit;var labels={m:['Distancia entre hileras (m)','Distancia entre plantas (m)'],cm:['Distancia entre hileras (cm)','Distancia entre plantas (cm)'],vara:['Distancia entre hileras (varas)','Distancia entre plantas (varas)']},phs={m:['ej. 0.50','ej. 0.40'],cm:['ej. 50','ej. 40'],vara:['ej. 0.60','ej. 0.48']};['a','b'].forEach(function(mode){var hLbl=document.getElementById('dens-hileras-'+mode+'-label'),pLbl=document.getElementById('dens-plantas-'+mode+'-label'),hInp=document.getElementById('dens-hileras-'+mode),pInp=document.getElementById('dens-plantas-'+mode);if(hLbl)hLbl.textContent=labels[unit][0];if(pLbl)pLbl.textContent=labels[unit][1];if(hInp){hInp.value='';hInp.placeholder=phs[unit][0];}if(pInp){pInp.value='';pInp.placeholder=phs[unit][1];}});['m','cm','vara'].forEach(function(u){var btn=document.getElementById('sp-btn-'+u);if(btn)btn.classList.toggle('active',u===unit);});}
function toMeters(val){if(currentSpacingUnit==='m')return val;if(currentSpacingUnit==='cm')return val/100;if(currentSpacingUnit==='vara')return val*VARA_TO_M;return val;}

/* ── Field visualization ── */
function drawField(hileras,plantas,densPerHa){var wrap=document.getElementById('pilv-viz-wrap'),canvas=document.getElementById('pilv-field-canvas');if(!wrap||!canvas)return;wrap.style.display='block';var ctx=canvas.getContext('2d'),W=canvas.width,H=canvas.height,maxCols=Math.min(Math.ceil(10/hileras),30),maxRows=Math.min(Math.ceil(10/plantas),20),padX=40,padY=40,cellW=(W-padX*2)/maxCols,cellH=(H-padY*2)/maxRows;ctx.fillStyle='#c9a87c';ctx.fillRect(0,0,W,H);for(var row=0;row<maxRows;row++){var y=padY+row*cellH+cellH/2;ctx.strokeStyle='rgba(44,110,63,0.15)';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(padX,y);ctx.lineTo(W-padX,y);ctx.stroke();for(var col=0;col<maxCols;col++){var x=padX+col*cellW+cellW/2,r=Math.min(cellW,cellH)*0.28;r=Math.max(3,Math.min(r,12));ctx.beginPath();ctx.arc(x,y,r,0,Math.PI*2);ctx.fillStyle='#2c6e3f';ctx.fill();ctx.beginPath();ctx.arc(x-r*0.25,y-r*0.25,r*0.4,0,Math.PI*2);ctx.fillStyle='rgba(255,255,255,0.25)';ctx.fill();}}if(maxCols>=2){var ay=padY/2,x1=padX+cellW/2,x2=padX+cellW*1.5;ctx.strokeStyle='#1a4a28';ctx.lineWidth=1.5;ctx.beginPath();ctx.moveTo(x1,ay);ctx.lineTo(x2,ay);ctx.stroke();ctx.fillStyle='#1a4a28';ctx.font='bold 11px sans-serif';ctx.textAlign='center';ctx.fillText(hileras+' m',(x1+x2)/2,ay-4);}if(maxRows>=2){var ax=padX/2,y1=padY+cellH/2,y2=padY+cellH*1.5;ctx.strokeStyle='#1a4a28';ctx.lineWidth=1.5;ctx.beginPath();ctx.moveTo(ax,y1);ctx.lineTo(ax,y2);ctx.stroke();ctx.save();ctx.translate(ax-4,(y1+y2)/2);ctx.rotate(-Math.PI/2);ctx.fillStyle='#1a4a28';ctx.font='bold 11px sans-serif';ctx.textAlign='center';ctx.fillText(plantas+' m',0,0);ctx.restore();}ctx.fillStyle='rgba(0,0,0,0.55)';ctx.font='10px sans-serif';ctx.textAlign='right';ctx.fillText('Vista representativa — no a escala',W-8,H-8);var cap=document.getElementById('pilv-viz-caption');if(cap)cap.textContent='Espaciamiento: '+hileras+' m entre hileras × '+plantas+' m entre plantas = '+fmt(densPerHa)+' plantas/ha';}

/* ── Density calculators ── */
function fillSpacingA(){var val=document.getElementById('dens-crop-a').value;if(!val||val==='custom')return;var p=val.split(',');document.getElementById('dens-hileras-a').value=p[0];document.getElementById('dens-plantas-a').value=p[1];}
function fillSpacingB(){var val=document.getElementById('dens-crop-b').value;if(!val||val==='custom')return;var p=val.split(',');document.getElementById('dens-hileras-b').value=p[0];document.getElementById('dens-plantas-b').value=p[1];}
function calcDensArea(){var rawArea=parseFloat(document.getElementById('dens-area').value),hileras=toMeters(parseFloat(document.getElementById('dens-hileras-a').value)),plantas=toMeters(parseFloat(document.getElementById('dens-plantas-a').value)),loss=parseInt(document.getElementById('dens-loss-a').value)/100;if(!rawArea||!hileras||!plantas){alert('Por favor completa todos los campos.');return;}var area=toHectares(rawArea),unitLabel=currentUnit==='ha'?rawArea+' ha':currentUnit==='m2'?fmt(rawArea)+' m²':rawArea+' cuadras ('+area.toFixed(2)+' ha)',areaM2=area*10000,densPerHa=Math.round(10000/(hileras*plantas)),totalBase=Math.round(areaM2/(hileras*plantas)),totalConLoss=Math.round(totalBase*(1+loss)),extraPlants=totalConLoss-totalBase;document.getElementById('dens-result-area-grid').innerHTML=resultItem(fmt(densPerHa),'plantas / hectárea')+resultItem(fmt(totalBase),'plantas necesarias')+(loss>0?resultItem(fmt(extraPlants),'plantas de margen (+'+Math.round(loss*100)+'%)'):'') +resultItem(fmt(totalConLoss),'TOTAL a solicitar');document.getElementById('dens-result-area-note').innerHTML='Para <strong>'+unitLabel+'</strong> con espaciamiento <strong>'+hileras+' × '+plantas+' m</strong>: densidad de <strong>'+fmt(densPerHa)+' plantas/ha</strong>.'+(loss>0?' Incluye <strong>'+Math.round(loss*100)+'% de margen</strong> por reposición. ':'')+' Solicite a Pilvicsa con al menos 14 días de anticipación.';document.getElementById('dens-result-area').classList.add('show');drawField(hileras,plantas,densPerHa);}
function calcDensPlants(){var nPlants=parseInt(document.getElementById('dens-nplants').value),hileras=toMeters(parseFloat(document.getElementById('dens-hileras-b').value)),plantas=toMeters(parseFloat(document.getElementById('dens-plantas-b').value));if(!nPlants||!hileras||!plantas){alert('Por favor completa todos los campos.');return;}var areaM2=nPlants*hileras*plantas,areaHa=areaM2/10000,densPerHa=Math.round(10000/(hileras*plantas));document.getElementById('dens-result-plants-grid').innerHTML=resultItem(fmt(areaM2),'m² requeridos')+resultItem(fmt(areaHa,2),'hectáreas')+resultItem(fmt(densPerHa),'plantas / hectárea');document.getElementById('dens-result-plants-note').innerHTML='<strong>'+fmt(nPlants)+' plantas</strong> con espaciamiento <strong>'+hileras+' × '+plantas+' m</strong> requieren <strong>'+fmt(areaHa,2)+' ha</strong> ('+fmt(areaM2)+' m²).';document.getElementById('dens-result-plants').classList.add('show');}
function resetDens(){['dens-area','dens-hileras-a','dens-plantas-a','dens-nplants','dens-hileras-b','dens-plantas-b'].forEach(function(id){var el=document.getElementById(id);if(el)el.value='';});['dens-crop-a','dens-crop-b'].forEach(function(id){var el=document.getElementById(id);if(el)el.selectedIndex=0;});document.getElementById('dens-result-area').classList.remove('show');document.getElementById('dens-result-plants').classList.remove('show');var viz=document.getElementById('pilv-viz-wrap');if(viz)viz.style.display='none';}

/* ── Calendar calculator ── */
function fillCalDays(){var val=document.getElementById('cal-crop').value;document.getElementById('cal-custom-fields').style.display=val==='custom'?'block':'none';}
function calcCalendar(){var harvestStr=document.getElementById('cal-harvest').value,cropVal=document.getElementById('cal-crop').value,orderDays=parseInt(document.getElementById('cal-order-days').value);if(!harvestStr){alert('Por favor selecciona la fecha de cosecha.');return;}if(!cropVal){alert('Por favor selecciona un cultivo.');return;}var fieldDays,nurseryDays,hardenDays;if(cropVal==='custom'){fieldDays=parseInt(document.getElementById('cal-field-days').value)||0;nurseryDays=parseInt(document.getElementById('cal-nursery-days').value)||0;hardenDays=parseInt(document.getElementById('cal-harden-days').value)||0;if(!fieldDays||!nurseryDays){alert('Por favor completa los días de campo y vivero.');return;}}else{var parts=cropVal.split(',');fieldDays=parseInt(parts[0]);nurseryDays=parseInt(parts[1]);hardenDays=parseInt(parts[2]);orderDays=Math.max(orderDays,parseInt(parts[3]));}var harvestDate=new Date(harvestStr+'T12:00:00'),transplantDate=subDays(harvestDate,fieldDays),exitNursery=subDays(transplantDate,hardenDays),seedDate=subDays(exitNursery,nurseryDays),orderDate=subDays(transplantDate,orderDays);document.getElementById('cal-timeline').innerHTML=['<div class="pilv-timeline-item highlight"><div class="tl-label">📋 Fecha para solicitar a Pilvicsa</div><div class="tl-date">'+fmtDate(orderDate)+'</div><div class="tl-desc">Solicite sus plántulas con al menos '+orderDays+' días de anticipación al trasplante</div></div>','<div class="pilv-timeline-item"><div class="tl-label">🌱 Siembra en vivero Pilvicsa</div><div class="tl-date">'+fmtDate(seedDate)+'</div><div class="tl-desc">Inicio de germinación — '+nurseryDays+' días en vivero</div></div>',hardenDays>0?'<div class="pilv-timeline-item"><div class="tl-label">🏠 Endurecimiento / Salida del vivero</div><div class="tl-date">'+fmtDate(exitNursery)+'</div><div class="tl-desc">Período de endurecimiento — '+hardenDays+' días antes del trasplante</div></div>':'','<div class="pilv-timeline-item"><div class="tl-label">🚜 Trasplante al campo</div><div class="tl-date">'+fmtDate(transplantDate)+'</div><div class="tl-desc">Plántula va al campo — '+fieldDays+' días hasta cosecha</div></div>','<div class="pilv-timeline-item highlight"><div class="tl-label">🌽 Cosecha objetivo</div><div class="tl-date">'+fmtDate(harvestDate)+'</div><div class="tl-desc">Fecha objetivo de cosecha ingresada</div></div>'].join('');document.getElementById('cal-result').classList.add('show');generateCalendarExport(harvestDate,transplantDate,seedDate,exitNursery,orderDate,hardenDays);}
function generateCalendarExport(harvestDate,transplantDate,seedDate,exitNursery,orderDate,hardenDays){var ts=Date.now(),cropLabel=document.getElementById('cal-crop'),cropName=cropLabel.options[cropLabel.selectedIndex].text.split('(')[0].trim();if(cropLabel.value==='custom')cropName='Cultivo personalizado';var events=[makeICSEvent('order-'+ts,'Solicitar plántulas a Pilvicsa — '+cropName,orderDate,'Fecha límite para pedir las plántulas de '+cropName+' a Pilvicsa. Tel: 032 235 011'),makeICSEvent('seed-'+ts,'Siembra en vivero Pilvicsa — '+cropName,seedDate,'Fecha estimada de siembra en el vivero para '+cropName)];if(hardenDays>0)events.push(makeICSEvent('harden-'+ts,'Endurecimiento — '+cropName,exitNursery,'Inicio de endurecimiento de plántulas de '+cropName));events.push(makeICSEvent('transplant-'+ts,'Trasplante al campo — '+cropName,transplantDate,'Fecha de trasplante al campo de '+cropName));events.push(makeICSEvent('harvest-'+ts,'Cosecha objetivo — '+cropName,harvestDate,'Fecha objetivo de cosecha de '+cropName));var ics=['BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//Pilvicsa//Calendario//ES','CALSCALE:GREGORIAN','METHOD:PUBLISH','X-WR-CALNAME:Pilvicsa — '+cropName,'X-WR-TIMEZONE:America/Guayaquil'].join('\r\n')+'\r\n'+events.join('\r\n')+'\r\nEND:VCALENDAR';var blob=new Blob([ics],{type:'text/calendar;charset=utf-8'}),url=URL.createObjectURL(blob),link=document.getElementById('cal-ics-link');link.href=url;link.download='pilvicsa-'+cropName.toLowerCase().replace(/\s+/g,'-')+'.ics';function gcalDate(d){return d.getFullYear()+''+pad(d.getMonth()+1)+''+pad(d.getDate());}var gcalUrl='https://calendar.google.com/calendar/render?action=TEMPLATE&text='+encodeURIComponent('Solicitar plántulas Pilvicsa — '+cropName)+'&dates='+gcalDate(orderDate)+'/'+gcalDate(new Date(orderDate.getTime()+86400000))+'&details='+encodeURIComponent('Solicitar plántulas de '+cropName+' a Pilvicsa.\nTel: 032 235 011\nwww.pilvicsa.com.ec');document.getElementById('cal-google-link').href=gcalUrl;document.getElementById('cal-export-block').style.display='block';}
function resetCal(){document.getElementById('cal-harvest').value='';document.getElementById('cal-crop').selectedIndex=0;document.getElementById('cal-custom-fields').style.display='none';document.getElementById('cal-result').classList.remove('show');document.getElementById('cal-export-block').style.display='none';var link=document.getElementById('cal-ics-link');if(link&&link.href.startsWith('blob:'))URL.revokeObjectURL(link.href);}

/* ── Crop rotation ── */
var ROT_DB={tomate:{fam:'Solanaceae',label:'Tomate',days:80,color:'#e74c3c',avoid:['pimiento','papa'],next:['brocoli','lechuga','maiz','zanahoria','frejol'],notes:'Evitar después de solanáceas. Rotar con crucíferas o leguminosas.'},pimiento:{fam:'Solanaceae',label:'Pimiento',days:90,color:'#e67e22',avoid:['tomate','papa'],next:['lechuga','maiz','zanahoria','frejol','brocoli'],notes:'Misma familia que el tomate. No repetir en el mismo lote por 2–3 ciclos.'},brocoli:{fam:'Brassicaceae',label:'Brócoli/Coliflor',days:75,color:'#27ae60',avoid:['brocoli'],next:['tomate','pimiento','cebolla','zanahoria','papa'],notes:'Crucífera — mejora la estructura del suelo. No repetir seguido.'},lechuga:{fam:'Asteraceae',label:'Lechuga/Espinaca',days:60,color:'#2ecc71',avoid:[],next:['tomate','zanahoria','cebolla','brocoli'],notes:'Cultivo liviano. Compatible con la mayoría de sucesores.'},cebolla:{fam:'Amaryllidaceae',label:'Cebolla/Ajo',days:90,color:'#9b59b6',avoid:['cebolla'],next:['zanahoria','lechuga','pepino','tomate','brocoli'],notes:'Allium — repele plagas. Excelente precedente para la mayoría de cultivos.'},zanahoria:{fam:'Apiaceae',label:'Zanahoria/Remolacha',days:90,color:'#e67e22',avoid:[],next:['tomate','lechuga','brocoli','frejol','cebolla'],notes:'Raíz profunda — mejora drenaje. Buena para seguir de hoja o solanáceas.'},pepino:{fam:'Cucurbitaceae',label:'Pepino/Melón/Sandía',days:80,color:'#1abc9c',avoid:['pepino'],next:['lechuga','cebolla','brocoli','zanahoria','frejol'],notes:'Cucurbitácea — rotar cada 2–3 ciclos. Evitar repetir con cucurbitáceas.'},maiz:{fam:'Poaceae',label:'Maíz',days:120,color:'#f1c40f',avoid:[],next:['frejol','arveja','brocoli','tomate','lechuga'],notes:'Gramínea. Excelente precursor — agota N pero deja buen rastrojo.'},papa:{fam:'Solanaceae',label:'Papa',days:90,color:'#95a5a6',avoid:['tomate','pimiento'],next:['maiz','brocoli','lechuga','frejol','zanahoria'],notes:'Solanácea. Muy exigente en suelo. Rotar obligatoriamente.'},frejol:{fam:'Fabaceae',label:'Fréjol/Chocho',days:70,color:'#e8a87c',avoid:[],next:['tomate','maiz','brocoli','pimiento','zanahoria'],notes:'Leguminosa — fija nitrógeno. Ideal como cultivo de transición.'},arveja:{fam:'Fabaceae',label:'Arveja/Habas',days:90,color:'#5dade2',avoid:[],next:['tomate','brocoli','lechuga','zanahoria','maiz'],notes:'Leguminosa — enriquece el suelo. Excelente para preceder solanáceas.'},gerbera:{fam:'Asteraceae',label:'Gerbera',days:110,color:'#e91e63',avoid:['gerbera'],next:['lechuga','brocoli','frejol'],notes:'Flor de corte. Rotar con cultivos de raíz o leguminosas.'},clavel:{fam:'Caryophyllaceae',label:'Clavel',days:90,color:'#f48fb1',avoid:['clavel'],next:['lechuga','brocoli','zanahoria','frejol'],notes:'Flor de corte. Rotar con cultivos anuales para romper ciclos de patógenos.'}};
function calcRotation(){var cropKey=document.getElementById('rot-crop').value,startStr=document.getElementById('rot-start').value,nPlots=parseInt(document.getElementById('rot-plots').value);if(!cropKey){alert('Por favor selecciona un cultivo.');return;}if(!startStr){alert('Por favor ingresa la fecha de inicio.');return;}var crop=ROT_DB[cropKey],startDate=new Date(startStr+'T12:00:00'),result=document.getElementById('rot-result'),grid=document.getElementById('rot-grid'),warn=document.getElementById('rot-warning'),sequence=[cropKey],avoidSet=[cropKey];for(var i=1;i<nPlots+3;i++){var prev=sequence[sequence.length-1],prevC=ROT_DB[prev],next=null;for(var j=0;j<prevC.next.length;j++){var candidate=prevC.next[j];if(avoidSet.slice(-2).indexOf(candidate)===-1){next=candidate;break;}}if(!next)next=prevC.next[0];sequence.push(next);avoidSet.push(next);}var lotes=[];for(var l=0;l<nPlots;l++){var loteSeq=[],currentDate=new Date(startDate);for(var s=0;s<4;s++){var idx=(l+s)%sequence.length,cKey=sequence[idx],cData=ROT_DB[cKey],endDate=addDays(currentDate,cData.days);loteSeq.push({key:cKey,data:cData,start:new Date(currentDate),end:new Date(endDate)});currentDate=addDays(endDate,14);}lotes.push(loteSeq);}grid.innerHTML='';lotes.forEach(function(lote,li){var card=document.createElement('div');card.style.cssText='background:#fff;border:1px solid #dde8dd;border-radius:8px;overflow:hidden;';card.innerHTML='<div style="background:#1a4a28;padding:10px 14px;color:#fff;font-size:.78rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;">Lote '+(li+1)+'</div>'+lote.map(function(cycle){var c=cycle.data;return'<div style="padding:10px 14px;border-bottom:1px solid #eef2ee;display:flex;align-items:center;gap:10px;"><div style="width:10px;height:10px;border-radius:50%;background:'+c.color+';flex-shrink:0;"></div><div><div style="font-weight:600;font-size:.9rem;">'+c.label+'</div><div style="font-size:.72rem;color:#888;">'+fmtDate(cycle.start)+' → '+fmtDate(cycle.end)+'</div></div></div>';}).join('');grid.appendChild(card);});var warnText='';crop.avoid.forEach(function(av){if(ROT_DB[av])warnText+='⚠️ No plantar <strong>'+ROT_DB[av].label+'</strong> en los lotes anteriores de '+crop.label+'. ';});warn.innerHTML=warnText;warn.style.display=warnText?'block':'none';result.classList.add('show');var icsEvents=[],ts=Date.now();lotes.forEach(function(lote,li){lote.forEach(function(cycle,ci){icsEvents.push(makeICSEvent('rot-L'+li+'C'+ci+'-'+ts,'Lote '+(li+1)+': '+cycle.data.label,cycle.start,'Cultivo: '+cycle.data.label+'\nFamilia: '+cycle.data.fam+'\n'+cycle.data.notes));});});var ics=['BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//Pilvicsa//Rotacion//ES','CALSCALE:GREGORIAN','X-WR-CALNAME:Pilvicsa — Rotación de Cultivos'].join('\r\n')+'\r\n'+icsEvents.join('\r\n')+'\r\nEND:VCALENDAR';document.getElementById('rot-ics-link').href=URL.createObjectURL(new Blob([ics],{type:'text/calendar;charset=utf-8'}));window._rotLotes=lotes;}
function downloadRotImage(){if(!window._rotLotes){alert('Genera el plan primero.');return;}var lotes=window._rotLotes,cropKey=document.getElementById('rot-crop').value,crop=ROT_DB[cropKey],W=540,rowH=44,headerH=100,loteHeaderH=36,padB=50,totalRows=lotes.reduce(function(s,l){return s+l.length;},0),H=headerH+lotes.length*loteHeaderH+totalRows*rowH+padB,canvas=document.getElementById('rot-canvas');canvas.width=W;canvas.height=H;var ctx=canvas.getContext('2d');ctx.fillStyle='#f4f9f5';ctx.fillRect(0,0,W,H);ctx.fillStyle='#1a4a28';ctx.fillRect(0,0,W,headerH);ctx.fillStyle='#fff';ctx.font='bold 20px sans-serif';ctx.textAlign='center';ctx.fillText('Pilvicsa — Rotación de Cultivos',W/2,36);ctx.font='14px sans-serif';ctx.fillStyle='rgba(255,255,255,0.8)';ctx.fillText('Cultivo inicial: '+crop.label+' · '+lotes.length+' lotes',W/2,62);ctx.font='11px sans-serif';ctx.fillStyle='rgba(255,255,255,0.55)';ctx.fillText('pilvicsa.com.ec',W/2,88);var y=headerH;lotes.forEach(function(lote,li){ctx.fillStyle='#2c6e3f';ctx.fillRect(0,y,W,loteHeaderH);ctx.fillStyle='#fff';ctx.font='bold 13px sans-serif';ctx.textAlign='left';ctx.fillText('  LOTE '+(li+1),20,y+23);y+=loteHeaderH;lote.forEach(function(cycle,ci){ctx.fillStyle=ci%2===0?'#fff':'#f4f9f5';ctx.fillRect(0,y,W,rowH);ctx.fillStyle=cycle.data.color;ctx.beginPath();ctx.arc(24,y+rowH/2,7,0,Math.PI*2);ctx.fill();ctx.fillStyle='#1a1a1a';ctx.font='bold 14px sans-serif';ctx.textAlign='left';ctx.fillText(cycle.data.label,40,y+20);ctx.font='12px sans-serif';ctx.fillStyle='#888';ctx.fillText(fmtDate(cycle.start)+' → '+fmtDate(cycle.end),40,y+36);y+=rowH;});});ctx.fillStyle='#bbb';ctx.font='11px sans-serif';ctx.textAlign='center';ctx.fillText('Generado por Pilvicsa · '+new Date().toLocaleDateString('es-EC'),W/2,H-16);var link=document.createElement('a');link.download='rotacion-pilvicsa.png';link.href=canvas.toDataURL('image/png');link.click();}
function resetRot(){document.getElementById('rot-crop').selectedIndex=0;document.getElementById('rot-start').value='';document.getElementById('rot-result').classList.remove('show');}

/* ── Image exports ── */
function downloadCalImage(){var timeline=document.getElementById('cal-timeline');if(!timeline||!timeline.innerHTML){alert('Genera el calendario primero.');return;}var cropEl=document.getElementById('cal-crop'),cropName=cropEl.options[cropEl.selectedIndex].text.split('(')[0].trim(),items=timeline.querySelectorAll('.pilv-timeline-item'),W=540,rowH=68,headerH=100,padB=50,H=headerH+items.length*rowH+padB,canvas=document.getElementById('cal-img-canvas');canvas.width=W;canvas.height=H;var ctx=canvas.getContext('2d');ctx.fillStyle='#f4f9f5';ctx.fillRect(0,0,W,H);ctx.fillStyle='#1a4a28';ctx.fillRect(0,0,W,headerH);ctx.fillStyle='#fff';ctx.font='bold 19px sans-serif';ctx.textAlign='center';ctx.fillText('Pilvicsa — Calendario de Trasplante',W/2,36);ctx.font='13px sans-serif';ctx.fillStyle='rgba(255,255,255,0.85)';ctx.fillText(cropName,W/2,60);ctx.font='11px sans-serif';ctx.fillStyle='rgba(255,255,255,0.55)';ctx.fillText('pilvicsa.com.ec · Tel: 032 235 011',W/2,88);items.forEach(function(item,i){var y=headerH+i*rowH,isHL=item.classList.contains('highlight');ctx.fillStyle=isHL?'#eaf4ec':i%2===0?'#fff':'#fafafa';ctx.fillRect(0,y,W,rowH);if(isHL){ctx.fillStyle='#2c6e3f';ctx.fillRect(0,y,5,rowH);}var label=item.querySelector('.tl-label'),date=item.querySelector('.tl-date'),desc=item.querySelector('.tl-desc');ctx.fillStyle=isHL?'#2c6e3f':'#888';ctx.font='bold 10px sans-serif';ctx.textAlign='left';if(label)ctx.fillText(label.textContent,16,y+16);ctx.fillStyle='#1a1a1a';ctx.font='bold 14px sans-serif';if(date)ctx.fillText(date.textContent,16,y+34);ctx.fillStyle='#888';ctx.font='11px sans-serif';if(desc)ctx.fillText(desc.textContent.substring(0,70),16,y+52);});ctx.fillStyle='#bbb';ctx.font='11px sans-serif';ctx.textAlign='center';ctx.fillText('Generado por Pilvicsa · '+new Date().toLocaleDateString('es-EC'),W/2,H-16);var link=document.createElement('a');link.download='calendario-trasplante-pilvicsa.png';link.href=canvas.toDataURL('image/png');link.click();}
function downloadDensImage(){var grid=document.getElementById('dens-result-area-grid');if(!grid||!grid.innerHTML){alert('Calcula la densidad primero.');return;}var items=grid.querySelectorAll('.pilv-result-item'),W=540,colW=130,headerH=100,padB=60,cols=Math.min(items.length,4),rows=Math.ceil(items.length/cols),H=headerH+rows*90+padB,canvas=document.getElementById('dens-img-canvas');canvas.width=W;canvas.height=H;var ctx=canvas.getContext('2d');ctx.fillStyle='#f4f9f5';ctx.fillRect(0,0,W,H);ctx.fillStyle='#1a4a28';ctx.fillRect(0,0,W,headerH);ctx.fillStyle='#fff';ctx.font='bold 19px sans-serif';ctx.textAlign='center';ctx.fillText('Pilvicsa — Densidad de Siembra',W/2,36);var area=document.getElementById('dens-area').value,hil=document.getElementById('dens-hileras-a').value,pl=document.getElementById('dens-plantas-a').value;ctx.font='13px sans-serif';ctx.fillStyle='rgba(255,255,255,0.85)';ctx.fillText(area+' '+currentUnit+' · Espaciamiento '+hil+' × '+pl+' m',W/2,60);ctx.font='11px sans-serif';ctx.fillStyle='rgba(255,255,255,0.55)';ctx.fillText('pilvicsa.com.ec · Tel: 032 235 011',W/2,88);var padX=(W-cols*colW)/2;items.forEach(function(item,i){var col=i%cols,row=Math.floor(i/cols),x=padX+col*colW,y=headerH+10+row*90,val=item.querySelector('.val'),unit=item.querySelector('.unit');ctx.fillStyle='#fff';ctx.strokeStyle='#dde8dd';ctx.lineWidth=1;ctx.beginPath();if(ctx.roundRect)ctx.roundRect(x+4,y,colW-8,74,8);else ctx.rect(x+4,y,colW-8,74);ctx.fill();ctx.stroke();ctx.fillStyle='#1a4a28';ctx.font='bold 18px sans-serif';ctx.textAlign='center';if(val)ctx.fillText(val.textContent,x+colW/2,y+32);ctx.fillStyle='#888';ctx.font='11px sans-serif';if(unit)ctx.fillText(unit.textContent,x+colW/2,y+52);});ctx.fillStyle='#bbb';ctx.font='11px sans-serif';ctx.textAlign='center';ctx.fillText('Generado por Pilvicsa · '+new Date().toLocaleDateString('es-EC'),W/2,H-20);var link=document.createElement('a');link.download='densidad-siembra-pilvicsa.png';link.href=canvas.toDataURL('image/png');link.click();}
</script>
</body>
</html>
